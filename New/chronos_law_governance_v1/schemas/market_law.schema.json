{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tradingagent.local/schemas/market_law.schema.json",
  "title": "Approved Market Chronos Law",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "law_id",
    "symbol",
    "name",
    "status",
    "enabled",
    "conditions",
    "effect",
    "governance"
  ],
  "properties": {
    "law_id": {
      "type": "string",
      "pattern": "^LAW_[0-9]{4,}$"
    },
    "source_candidate_id": {
      "type": "string"
    },
    "symbol": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "APPROVED",
        "DISABLED",
        "RETIRED"
      ]
    },
    "enabled": {
      "type": "boolean"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "conditions": {
      "type": "object"
    },
    "effect": {
      "type": "object",
      "required": [
        "supporting_side",
        "blocked_actions"
      ],
      "properties": {
        "supporting_side": {
          "type": "string",
          "enum": [
            "BUY",
            "SELL",
            "NONE"
          ]
        },
        "blocked_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "BUY",
              "SELL"
            ]
          },
          "uniqueItems": true
        },
        "action_hint": {
          "type": "string"
        }
      }
    },
    "validation_snapshot": {
      "type": "object"
    },
    "health": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "HEALTHY",
            "WATCH",
            "DEGRADED",
            "UNKNOWN"
          ]
        },
        "checked_at_utc": {
          "type": [
            "string",
            "null"
          ]
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "governance": {
      "type": "object",
      "required": [
        "approved_at_utc",
        "approved_by",
        "approval_reason"
      ],
      "properties": {
        "approved_at_utc": {
          "type": "string"
        },
        "approved_by": {
          "type": "string"
        },
        "approval_reason": {
          "type": "string"
        },
        "disabled_at_utc": {
          "type": [
            "string",
            "null"
          ]
        },
        "disabled_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "disable_reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}